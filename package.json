{
	"name": "skillsmatch",
	"version": "1.0.0",
	"author": {
		"name": "Mark Wong"
	},
	"private": true,
	"description": "AI-powered fitness coaching for busy office professionals",
	"engines": {
		"node": ">=22",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@10.30.3",
	"scripts": {
		"dev:all": "pnpm --parallel --filter client --filter server dev",
		"dev:client": "pnpm --filter client dev",
		"dev:server": "pnpm --filter server dev",
		"build": "pnpm --recursive build",
		"lint": "pnpm --recursive lint",
		"test": "pnpm --recursive test --run",
		"db:migrate": "pnpm --filter server db:migrate",
		"db:migrate:reset": "pnpm --filter server db:migrate:reset",
		"db:studio": "pnpm --filter server db:studio",
		"db:seed": "pnpm --filter server db:seed",
		"db:generate": "pnpm --filter server db:generate",
		"docker:up": "docker-compose up -d",
		"docker:down": "docker-compose down",
		"docker:reset": "docker-compose down -v",
		"docker:logs": "docker-compose logs -f postgres"
	},
	"workspaces": [
		"client",
		"server"
	]
}
