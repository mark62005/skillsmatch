	"type": "module",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.0.0",
		"@aws-sdk/s3-request-presigner": "^3.0.0",
		"@clerk/express": "^1.7.66",
		"@google/generative-ai": "^0.21.0",
		"@prisma/adapter-pg": "^7.4.2",
		"@prisma/client": "^7.3.0",
		"cors": "^2.8.6",
		"dotenv": "^16.0.0",
